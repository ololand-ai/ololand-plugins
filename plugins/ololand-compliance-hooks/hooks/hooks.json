{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/mnpi_guard.sh\"",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/mnpi_guard.sh\"",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "mcp__ololand__.*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/audit_log.sh\" pre",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__ololand__generate_investment_memo|mcp__ololand__generate_cim|mcp__ololand__export_deal_dossier",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/citation_enforcer.sh\"",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/provenance_writeback.sh\"",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "mcp__ololand__.*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/audit_log.sh\" post",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/tier_capacity_warning.sh\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "mcp__ololand__get_assumption_evidence_pack|mcp__ololand__get_assumption_control_summary|mcp__ololand__set_assumption_status|mcp__ololand__generate_investment_memo|mcp__ololand__export_deal_dossier",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/evidence_quality_warning.sh\"",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/citation_enforcer.sh\"",
            "timeout": 30
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"${CLAUDE_PLUGIN_ROOT}\" ] && bash \"${CLAUDE_PLUGIN_ROOT}/scripts/session_banner.sh\" || echo \"[ololand-compliance-hooks] CLAUDE_PLUGIN_ROOT unset; session banner skipped\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
